    },
    "paths": {
        "/users/list": {
            "get": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "Query users list",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
